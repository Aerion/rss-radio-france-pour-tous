# Copy this file to .env and fill in real values. .env is gitignored.

# Required. The x-token header value for Radio France's unofficial mobile
# API. See src/api.js in the pre-rewrite history, or the project README,
# for where this comes from.
RADIOFRANCE_API_TOKEN=changeme

# Externally-visible base URL for this app, used to build self-referencing
# links (RSS enclosures/pagination, search result URLs). For local docker
# compose this can stay as the default below.
PUBLIC_BASE_URL=http://localhost:8080

# Required. Postgres password for the analytics database.
POSTGRES_PASSWORD=changeme

# Optional. Comma-separated, case-insensitive substrings; any request to
# /rss/ or /audio/ whose User-Agent contains one of these gets a 403.
# Example: BLOCKED_USER_AGENTS=GPTBot,Bytespider,AhrefsBot
BLOCKED_USER_AGENTS=

# Optional. How long a rendered feed page is served from the in-memory feed
# cache before a plain rebuild. Default: 1h
FEED_CACHE_TTL=

# Optional. How often the feed cache's background sweep evicts expired
# entries. Default: 5m
FEED_CACHE_SWEEP_INTERVAL=

# Optional. Fallback freshness window for a cached manifestation URL when
# Radio France doesn't report its own expiry. Default: 720h (30 days)
MANIFESTATION_CACHE_MAX_AGE=

# Optional. How many pending episode-enrichment jobs the queue holds before
# new ones are dropped. Default: 500
ENRICHMENT_QUEUE_SIZE=

# Optional. Enrichment worker pool size - the dial that keeps upstream
# concurrency low regardless of request volume. Default: 2
ENRICHMENT_WORKERS=

# Optional. Per-job timeout for an enrichment worker's upstream call(s).
# Default: 15s
ENRICHMENT_JOB_TIMEOUT=
