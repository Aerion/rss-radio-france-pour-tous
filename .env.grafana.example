# Copy this file to .env.grafana and fill in real values. It is gitignored.
# This is separate because these variables are passed only to Grafana.

# Used by the provisioned Postgres datasource. It must match POSTGRES_PASSWORD
# from the main .env file.
POSTGRES_PASSWORD=changeme

# Required only when Grafana creates a fresh grafana_data volume.
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme

# The externally visible Grafana URL, including its trailing slash.
GF_SERVER_ROOT_URL=https://example.invalid/grafana/
GF_SERVER_SERVE_FROM_SUB_PATH=true
GF_AUTH_ANONYMOUS_ENABLED=false
